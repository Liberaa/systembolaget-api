        {
          "name": "Register - Success",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set(\"regUsername\", \"user_\" + Math.random().toString(36).slice(2, 8))",
                  "pm.environment.set(\"regEmail\", \"test_\" + Math.random().toString(36).slice(2, 10) + \"@example.com\")",
                  "pm.environment.set(\"regPassword\", \"password123\")"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200))",
                  "const json = pm.response.json()",
                  "pm.test(\"No errors\", () => pm.expect(json.errors).to.be.undefined)",
                  "pm.test(\"Token returned\", () => pm.expect(json.data.register.token).to.be.a(\"string\"))",
                  "pm.test(\"User has email\", () => pm.expect(json.data.register.user.email).to.include(\"@\"))",
                  "pm.environment.set(\"token\", json.data.register.token)",
                  "pm.environment.set(\"userId\", json.data.register.user.id)"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation Register($username: String!, $email: String!, $password: String!) {\\n  register(username: $username, email: $email, password: $password) {\\n    token\\n    user { id username email }\\n  }\\n}\",\"variables\":{\"username\":\"{{regUsername}}\",\"email\":\"{{regEmail}}\",\"password\":\"{{regPassword}}\"}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
