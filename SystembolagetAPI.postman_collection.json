        {
          "name": "Add Product - Success",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set(\"newProductName\", \"Test Wine \" + Math.random().toString(36).slice(2, 8))"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200))",
                  "const json = pm.response.json()",
                  "pm.test(\"No errors\", () => pm.expect(json.errors).to.be.undefined)",
                  "pm.test(\"Product created with ID\", () => pm.expect(json.data.addProduct.id).to.be.a(\"string\"))",
                  "pm.test(\"Name matches\", () => pm.expect(json.data.addProduct.name).to.equal(pm.environment.get(\"newProductName\")))",
                  "pm.test(\"Price correct\", () => pm.expect(json.data.addProduct.price).to.equal(149))",
                  "pm.environment.set(\"newProductId\", json.data.addProduct.id)"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation AddProduct($name: String!, $price: Float, $productGroup: String, $originCountry: String, $alcoholContent: String, $volumeMl: Float) {\\n  addProduct(name: $name, price: $price, productGroup: $productGroup, originCountry: $originCountry, alcoholContent: $alcoholContent, volumeMl: $volumeMl) {\\n    id name price productGroup originCountry alcoholContent volumeMl\\n  }\\n}\",\"variables\":{\"name\":\"{{newProductName}}\",\"price\":149,\"productGroup\":\"Red wine\",\"originCountry\":\"France\",\"alcoholContent\":\"13.5%\",\"volumeMl\":750}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
